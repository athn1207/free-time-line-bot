# ===========================================
# 環境変数サンプル（.env にコピーして値を設定）
# ===========================================

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- サーバー ---
# デプロイ先の URL（OAuth コールバックで必須）。末尾スラッシュなし
BASE_URL=https://your-app-name.onrender.com
PORT=3000

# --- Google Calendar API ---
# 【マルチユーザー】PostgreSQL を使う場合は DATABASE_URL を設定し、
# 以下 2 つを設定。ユーザーごとの refresh_token は DB に保存される
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 【単一ユーザー】DB を使わない場合はリフレッシュトークンをここに設定
# GOOGLE_REFRESH_TOKEN=

# 使用するカレンダー ID（未設定時は primary）
# GOOGLE_CALENDAR_ID=primary

# --- マルチユーザー用（Render PostgreSQL の Internal Database URL）---
# 設定すると「連携」でユーザー別 Google OAuth が有効になる
# DATABASE_URL=postgres://...
