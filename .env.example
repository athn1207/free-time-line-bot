# ===========================================
# 環境変数サンプル（.env にコピーして値を設定）
# ===========================================

# --- LINE Messaging API ---
# LINE Developers でチャネルを作成し、Messaging API を有効にしたあと取得
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- Google Calendar API（テスト用）---
# 現在は「テスト用固定トークン」で動作。OAuth 導入時はここは不要になる
# Google Cloud Console で OAuth 2.0 クライアントを作成し、
# 手動で取得したアクセストークン（またはサービスアカウントのキー）を設定
GOOGLE_ACCESS_TOKEN=

# 本番ではユーザーごとに tokenStore に保存するため、ここはフォールバック用
# 未設定の場合は各ユーザーの tokenStore のトークンを使用

# --- サーバー ---
# デプロイ先の URL（Webhook 検証や将来的な OAuth コールバックで使用）
BASE_URL=https://your-app-name.onrender.com
PORT=3000
